# ===== SERVER =====
PORT=8000

# ===== MONGODB =====
# Lokal: mongodb://127.0.0.1:27017/toy_uz
# Railway: Railway "MongoDB" plugin bergan ulanish manzilini qo'ying
MONGO_URI=mongodb://127.0.0.1:27017/toy_uz

# ===== AUTH =====
JWT_SECRET=toyuz_maxfiy_kalit_2025_ozgartiring
JWT_EXPIRE=30d

# ===== CORS / FRONTEND =====
# Frontend manzili. Bir nechta bo'lsa vergul bilan:
# CLIENT_URL=https://toy-uz.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173

# ===== TELEGRAM BOT =====
# @BotFather dan token oling. Bo'sh bo'lsa bot o'chiq turadi (qolgani ishlayveradi).
TELEGRAM_BOT_TOKEN=

# WebApp (Mini App) manzili — botdagi "Panelni ochish" tugmasi shu yerga ochadi.
# HTTPS bo'lishi SHART (Vercel domeni). Bo'sh bo'lsa CLIENT_URL ishlatiladi.
# WEBAPP_URL=https://toy-uz.vercel.app
